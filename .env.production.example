# Production example
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:replace-password@db-host:5432/booking_app
VERCEL=false

# Public URL
# Render / Railway では未設定でも自動推定できますが、Google OAuth を使うなら明示推奨
PUBLIC_BASE_URL=https://your-app.example.com

# Required in production
BOOKING_ADMIN_SECRET=replace-with-long-random-admin-secret
BOOKING_SESSION_SECRET=replace-with-long-random-session-secret
BOOKING_SEED_DEMO=false

# Optional but recommended
SECURITY_TRUSTED_HOSTS=your-app.example.com
SECURITY_FORCE_HTTPS_REDIRECT=true
SECURITY_HSTS_SECONDS=31536000
AUTH_RATE_LIMIT_WINDOW_SEC=900
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_RESET_RATE_LIMIT_WINDOW_SEC=3600
PASSWORD_RESET_RATE_LIMIT_MAX_ATTEMPTS=5
BOOKING_PUBLIC_RATE_LIMIT_WINDOW_SEC=3600
BOOKING_PUBLIC_RATE_LIMIT_MAX_REQUESTS=40
BOOKING_DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-fernet-key
API_DOCS_ENABLED=false

# Optional bootstrap admin (first startup only)
# BOOKING_BOOTSTRAP_ADMIN_USER=admin
# BOOKING_BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-password

# In Vercel, keep startup side effects disabled unless you explicitly need them
# STARTUP_INIT_DB=false
# STARTUP_BOOTSTRAP_ADMIN=false
# STARTUP_SEED_DEMO=false
# STARTUP_EMBEDDED_JOBS=false

BOOKING_JOBS_CRON=*/5 * * * *
BOOKING_REMINDER_HOURS_BEFORE=24
BOOKING_STAFF_REMINDER_HOURS_BEFORE=24
BOOKING_REMINDER_SECOND_HOURS_BEFORE=1
BOOKING_BUFFER_MINUTES=0
BOOKING_REPEAT_OUTREACH_DAYS=30

# Google Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.example.com/api/booking/oauth/google/callback
ZOOM_DEFAULT_MEETING_URL=
TEAMS_DEFAULT_MEETING_URL=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_SSL=false
SMTP_STARTTLS=true
