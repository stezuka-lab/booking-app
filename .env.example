# Server
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# --- オンライン予約管理のみ（解約検知 AI は ../churn-insight-app/）---
#
# PUBLIC_BASE_URL … メール内 URL・OAuth 用（末尾スラッシュなし）
# LAN で使う場合は run_server.bat が http://<LAN_IP>:8000 に一時上書き
# BOOKING_ADMIN_SECRET … 空で管理者 API 無効
#
PUBLIC_BASE_URL=http://127.0.0.1:8000
BOOKING_ADMIN_SECRET=dev-demo-secret
# 初回のみ（DB にユーザーが 0 件のとき 1 回だけ管理者を自動作成）
# BOOKING_BOOTSTRAP_ADMIN_USER=admin
# BOOKING_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
BOOKING_SESSION_SECRET=
BOOKING_SEED_DEMO=true
SECURITY_TRUSTED_HOSTS=
SECURITY_FORCE_HTTPS_REDIRECT=false
SECURITY_HSTS_SECONDS=31536000
AUTH_RATE_LIMIT_WINDOW_SEC=900
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_RESET_RATE_LIMIT_WINDOW_SEC=3600
PASSWORD_RESET_RATE_LIMIT_MAX_ATTEMPTS=5
BOOKING_PUBLIC_RATE_LIMIT_WINDOW_SEC=3600
BOOKING_PUBLIC_RATE_LIMIT_MAX_REQUESTS=40
BOOKING_DATA_ENCRYPTION_KEY=
API_DOCS_ENABLED=true
BOOKING_JOBS_CRON=*/5 * * * *
BOOKING_REMINDER_HOURS_BEFORE=24
BOOKING_STAFF_REMINDER_HOURS_BEFORE=24
BOOKING_REMINDER_SECOND_HOURS_BEFORE=1
# 組織で buffer_minutes 未設定時の既定（0 推奨＝重なりのみで判定）
BOOKING_BUFFER_MINUTES=0
BOOKING_REPEAT_OUTREACH_DAYS=30

# Google Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/booking/oauth/google/callback
ZOOM_DEFAULT_MEETING_URL=
TEAMS_DEFAULT_MEETING_URL=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=

# 予約メール通知（任意）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
